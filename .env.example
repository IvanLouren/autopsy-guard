# AutopsyGuard — secrets / sensitive environment variables
# Copy this file to .env and fill in your values.
#
# AutopsyGuard loads .env automatically from the current working directory
# when it starts. You can also point to a custom location:
#
#   autopsyguard --env-file /path/to/secrets.env
#
# Lines starting with '#' are comments and are ignored.
# Values do NOT need to be quoted (but quoting is supported).
# Variables already present in the shell environment take priority
# over values set here (so you can always override from the shell).

# ── Email / SMTP ─────────────────────────────────────────────────────────────
AUTOPSYGUARD_SMTP_USER=your-smtp-username
AUTOPSYGUARD_SMTP_PASSWORD=your-smtp-password
AUTOPSYGUARD_SMTP_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# ── WhatsApp (CallMeBot) ──────────────────────────────────────────────────────
AUTOPSYGUARD_WHATSAPP_APIKEY=your-callmebot-api-key
